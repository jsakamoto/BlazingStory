{
  "$schema": "http://json.schemastore.org/template",
  "author": "J.Sakamoto",
  "classifications": [
    "Web",
    "Blazor",
    "Test"
  ],
  "groupIdentity": "BlazingStory.VRT",
  "identity": "BlazingStory.VRT.CSharp.1.0",
  "precedence": "7000",
  "name": "Blazing Story Visual Regression Test",
  "shortName": "blazingstoryvrt",
  "description": "A project template for creating a Visual Regression Test project for a Blazing Story app.",
  "thirdPartyNotices": "https://github.com/jsakamoto/BlazingStory/blob/main/THIRD-PARTY-NOTICES.txt",
  "defaultName": "BlazorApp.Stories.VRT",
  "preferNameDirectory": true,
  "tags": {
    "language": "TypeScript",
    "type": "project"
  },
  "symbols": {
    "HostIdentifier": {
      "type": "bind",
      "binding": "HostIdentifier"
    },
    "baseURL":{
      "type": "parameter",
      "description": "A base URL where the Blazing Story app under test is running.",
      "datatype": "text",
      "isRequired": true,
      "replaces": "BASE_URL"
    },
    "SnapshotsStorage": {
      "type": "parameter",
      "description": "A storage service for UI snapshots to store and share images.",
      "datatype": "choice",
      "defaultValue": "none",
      "choices": [
        {
          "choice": "aws",
          "description": "Amazon Web Service S3"
        },
        {
          "choice": "azure",
          "description": "Microsoft Azure Blob Storage"
        },
        {
          "choice": "gcp",
          "description": "Google Cloud Storage"
        },
        {
          "choice": "custom",
          "description": "Implement an adapter for your own custom storage"
        },
        {
          "choice": "none",
          "description": "Do not store in any storage services"
        }
      ]
    },
    "AwsS3RegionName":{
      "type": "parameter",
      "description": "AWS S3 region name holding the shared VRT baseline screenshots",
      "datatype": "text",
      "isEnabled": "SnapshotsStorage == \"aws\"",
      "isRequired": true,
      "replaces": "AWS_S3_REGION_NAME"
    },
    "AwsS3BucketName":{
      "type": "parameter",
      "description": "AWS S3 bucket name holding the shared VRT baseline screenshots",
      "datatype": "text",
      "isEnabled": "SnapshotsStorage == \"aws\"",
      "isRequired": true,
      "replaces": "AWS_S3_BUCKET_NAME"
    },
    "AzureStorageAccouontName":{
      "type": "parameter",
      "description": "Azure Storage Account name holding the shared VRT baseline screenshots",
      "datatype": "text",
      "isEnabled": "SnapshotsStorage == \"azure\"",
      "isRequired": true,
      "replaces": "AZURE_STORAGE_ACCOUNT_NAME"
    },
    "AzureStorageContainerName":{
      "type": "parameter",
      "description": "Azure Storage Container name holding the shared VRT baseline screenshots",
      "datatype": "text",
      "isEnabled": "SnapshotsStorage == \"azure\"",
      "isRequired": true,
      "replaces": "AZURE_STORAGE_CONTAINER_NAME"
    },
    "GoogleCloudStorageBucketName":{
      "type": "parameter",
      "description": "Google Cloud Storage Bucket name holding the shared VRT baseline screenshots",
      "datatype": "text",
      "isEnabled": "SnapshotsStorage == \"gcp\"",
      "isRequired": true,
      "replaces": "GOOGLE_CLOUD_STORAGE_BUCKET_NAME"
    },
    "AIAgentToImplementCustomStorage":{
      "type": "parameter",
      "description": "AI agent to implement a custom storage adapter. Skills for implementing custom storage adapters will be stored in the appropriate folder for your chosen agent.",
      "datatype": "choice",
      "isEnabled": "SnapshotsStorage == \"custom\"",
      "defaultValue": "none",
      "choices": [
        {
          "choice": "claude",
          "description": "Claude Code"
        },
        {
          "choice": "generic",
          "description": "GitHub Copilot, OpenAI Codex, Cursor, etc."
        },
        {
          "choice": "none",
          "description": "No AI agent"
        }
      ]
    }
  },
  "sourceName": "StoryVRT",
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
        ".template.config/**"
      ],
      "copyOnly": [],
      "modifiers": [
        {
          "condition": "SnapshotsStorage == \"aws\"",
          "exclude": [
            "README.azure.md",
            "README.gcp.md",
            "README.custom.md",
            "README.local.md",
            "scripts/snapshot-storage.azure.ts",
            "scripts/snapshot-storage.gcp.ts",
            "scripts/snapshot-storage.custom.ts",
            "scripts/snapshot-storage.local.ts"
          ],
          "rename": {
            "README.aws.md": "README.md",
            "scripts/snapshot-storage.aws.ts": "scripts/snapshot-storage.ts"
          }
        },
        {
          "condition": "SnapshotsStorage == \"azure\"",
          "exclude": [
            "README.aws.md",
            "README.gcp.md",
            "README.custom.md",
            "README.local.md",
            "scripts/snapshot-storage.aws.ts",
            "scripts/snapshot-storage.gcp.ts",
            "scripts/snapshot-storage.custom.ts",
            "scripts/snapshot-storage.local.ts"
          ],
          "rename": {
            "README.azure.md": "README.md",
            "scripts/snapshot-storage.azure.ts": "scripts/snapshot-storage.ts"
          }
        },
        {
          "condition": "SnapshotsStorage == \"gcp\"",
          "exclude": [
            "README.aws.md",
            "README.azure.md",
            "README.custom.md",
            "README.local.md",
            "scripts/snapshot-storage.aws.ts",
            "scripts/snapshot-storage.azure.ts",
            "scripts/snapshot-storage.custom.ts",
            "scripts/snapshot-storage.local.ts"
          ],
          "rename": {
            "README.gcp.md": "README.md",
            "scripts/snapshot-storage.gcp.ts": "scripts/snapshot-storage.ts"
          }
        },
        {
          "condition": "SnapshotsStorage == \"custom\"",
          "exclude": [
            "README.aws.md",
            "README.azure.md",
            "README.gcp.md",
            "README.local.md",
            "scripts/snapshot-storage.aws.ts",
            "scripts/snapshot-storage.azure.ts",
            "scripts/snapshot-storage.gcp.ts",
            "scripts/snapshot-storage.local.ts"
          ],
          "rename": {
            "README.custom.md": "README.md",
            "scripts/snapshot-storage.custom.ts": "scripts/snapshot-storage.ts"
          }
        },
        {
          "condition": "SnapshotsStorage == \"none\"",
          "exclude": [
            "README.aws.md",
            "README.azure.md",
            "README.gcp.md",
            "README.custom.md",
            "scripts/snapshot-storage.aws.ts",
            "scripts/snapshot-storage.azure.ts",
            "scripts/snapshot-storage.gcp.ts",
            "scripts/snapshot-storage.custom.ts",
            "scripts/snapshot-sync.ts",
            "scripts/snapshots-push.ts",
            "scripts/snapshots-pull.ts"
          ],
          "rename": {
            "README.local.md": "README.md"
          }
        },
        {
          "rename": {
            "vscode": ".vscode"
          }
        },
        {
          "condition": "(SnapshotsStorage != \"custom\") || (AIAgentToImplementCustomStorage == \"none\")",
          "exclude": [".agents/**"]
        },
        {
          "condition": "(SnapshotsStorage == \"custom\") && (AIAgentToImplementCustomStorage == \"claude\")",
          "rename": {
            ".agents": ".claude"
          }
        }
      ]
    }
  ],
  "primaryOutputs": [
    {
      "path": "StoryVRT.esproj"
    }
  ],
  "postActions": []
}