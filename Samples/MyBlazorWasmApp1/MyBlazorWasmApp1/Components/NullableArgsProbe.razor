<section class="nullable-args-probe">
    <h4 class="nullable-args-probe__title">@this.Title</h4>
    <ul class="nullable-args-probe__list">
        <li>NullableBool: @Format(this.NullableBool)</li>
        <li>NullableCount: @Format(this.NullableCount)</li>
        <li>NullableMode: @Format(this.NullableMode)</li>
        <li>NullableColor: @Format(this.NullableColor)</li>
        <li>NonNullableText: @this.NonNullableText</li>
    </ul>
</section>

@code
{
    [Parameter]
    public string Title { get; set; } = "Nullable Args Probe";

    [Parameter]
    public bool? NullableBool { get; set; }

    [Parameter]
    public int? NullableCount { get; set; }

    [Parameter]
    public ProbeMode? NullableMode { get; set; }

    [Parameter]
    public string? NullableColor { get; set; }

    [Parameter]
    public string NonNullableText { get; set; } = "default";

    private static string Format<T>(T value)
    {
        return value is null ? "null" : value.ToString() ?? string.Empty;
    }

    public enum ProbeMode
    {
        Basic,
        Advanced,
        Expert
    }
}
