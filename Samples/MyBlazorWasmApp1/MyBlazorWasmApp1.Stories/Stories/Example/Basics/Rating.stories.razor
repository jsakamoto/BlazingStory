@attribute [Stories("Example/Rating")]

<Stories TComponent="Rating">
    <ArgType For="_=>_!.Color" Control="ControlType.Color" DefaultValue='"goldenrod"' />

    <Story Name="Default">
        <Description>
            Uses only template-fixed value and lets controls manipulate Max and Color args.
        </Description>
        <Template>
            <Rating Value="3" @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="10 Stars">
        <Arguments>
            <Arg For="_ => _!.Max" Value="10" />
        </Arguments>
        <Template>
            <Rating Value="3" @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Zero Value">
        <Template>
            <Rating Value="0" @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Custom Color">
        <Arguments>
            <Arg For="_ => _!.Color" Value="_CustomColor" />
        </Arguments>
        <Template>
            <Rating Value="4" @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Value Greater Than Max">
        <Description>
            Edge-case example to show how component rendering behaves when Value exceeds Max.
        </Description>
        <Arguments>
            <Arg For="_ => _!.Max" Value="5" />
        </Arguments>
        <Template>
            <Rating Value="7" @attributes="context.Args" />
        </Template>
    </Story>

</Stories>

@code
{
    private string _CustomColor = "tomato";
}

