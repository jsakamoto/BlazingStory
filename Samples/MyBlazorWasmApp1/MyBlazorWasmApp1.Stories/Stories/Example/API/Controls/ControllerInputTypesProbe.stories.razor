@attribute [Stories("Example/API/Controls/Controller Input Types")]

<Stories TComponent="ControllerInputTypesProbe" Layout="typeof(CenteredLayout)">

    <Story Name="Arrays And RenderFragment">
        <Description>
            Demonstrates built-in array and render-fragment parameter controllers in one place.
        </Description>
        <Arguments>
            <Arg For="_ => _.Tags" Value="_Tags" />
            <Arg For="_ => _.Numbers" Value="_Numbers" />
            <Arg For="_ => _.Flags" Value="_Flags" />
            <Arg For="_ => _.Levels" Value="_Levels" />
            <Arg For="_ => _.Template" Value="_Template" />
        </Arguments>
        <Template>
            <ControllerInputTypesProbe @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Nullable Arrays">
        <Arguments>
            <Arg For="_ => _.Tags" Value="_NullTags" />
            <Arg For="_ => _.Numbers" Value="_NullNumbers" />
            <Arg For="_ => _.Flags" Value="_NullFlags" />
            <Arg For="_ => _.Levels" Value="_NullLevels" />
            <Arg For="_ => _.Template" Value="_Template" />
        </Arguments>
        <Template>
            <ControllerInputTypesProbe @attributes="context.Args" />
        </Template>
    </Story>
</Stories>

@code
{
    private string[] _Tags = ["alpha", "beta", "gamma"];

    private int[] _Numbers = [1, 2, 3, 8, 13];

    private bool[] _Flags = [true, false, true];

    private ControllerInputTypesProbe.Level[] _Levels =
    [
        ControllerInputTypesProbe.Level.Low,
        ControllerInputTypesProbe.Level.Medium,
        ControllerInputTypesProbe.Level.High
    ];

    private string[]? _NullTags = null;

    private int[]? _NullNumbers = null;

    private bool[]? _NullFlags = null;

    private ControllerInputTypesProbe.Level[]? _NullLevels = null;

    private RenderFragment _Template = @<text><b>Editable fragment content</b> from initial args.</text>;
}
