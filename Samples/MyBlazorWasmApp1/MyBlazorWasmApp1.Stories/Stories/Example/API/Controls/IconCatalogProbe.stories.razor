@attribute [Stories("Example/API/Controls/Long Enum Controls")]

<Stories TComponent="IconCatalogProbe" Layout="typeof(CenteredLayout)">
    <ArgType For="_ => _.IconSelect" Control="ControlType.Select" />
    <ArgType For="_ => _.IconRadio" Control="ControlType.Radio" />

    <Story Name="Long Enum In Select And Radio">
        <Description>
            Demonstrates behavior with a long enum list. Select stays compact, radio becomes verbose.
        </Description>
        <Arguments>
            <Arg For="_ => _.IconSelect" Value="IconCatalogProbe.IconToken.Filter" />
            <Arg For="_ => _.IconRadio" Value="IconCatalogProbe.IconToken.Filter" />
        </Arguments>
        <Template>
            <IconCatalogProbe @attributes="context.Args" />
        </Template>
    </Story>
</Stories>
