@attribute [Stories("Example/API/Args/Playground Card")]

<Stories TComponent="PlaygroundCard" Layout="typeof(CenteredLayout)">
    <ArgType For="_=>_.AccentColor" Control="ControlType.Color" DefaultValue='"#4f46e5"' />
    <ArgType For="_=>_.Tone" Control="ControlType.Select" DefaultValue="PlaygroundCard.CardTone.Info" />

    <Story Name="Default Args Surface">
        <Description>
            Demonstrates bool, string, enum, int, render-fragment and unmatched-attribute parameters.
        </Description>
        <Arguments>
            <Arg For="_ => _.Title" Value="_DefaultTitle" />
            <Arg For="_ => _.Score" Value="3" />
            <Arg For="_ => _.ShowBadge" Value="true" />
            <Arg For="_ => _.ChildContent" Value="_DefaultContent" />
            <Arg For="_ => _.Attributes" Value="_CardAttributes" />
        </Arguments>
        <Template>
            <PlaygroundCard @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="Story-Level Layout Override" Layout="typeof(FullFrameLayout)">
        <Description>
            Demonstrates per-story layout override without duplicating style variants of the same scenario.
        </Description>
        <Arguments>
            <Arg For="_ => _.Title" Value="_WideTitle" />
            <Arg For="_ => _.ShowBadge" Value="false" />
            <Arg For="_ => _.Score" Value="8" />
            <Arg For="_ => _.ChildContent" Value="_WideContent" />
        </Arguments>
        <Template>
            <PlaygroundCard @attributes="context.Args" />
        </Template>
    </Story>

    <Story Name="EventCallback State Sync">
        <Description>
            Demonstrates EventCallback&lt;int&gt; by syncing component actions with local story state.
        </Description>
        <Arguments>
            <Arg For="_ => _.Title" Value="_CallbackTitle" />
            <Arg For="_ => _.Score" Value="_CurrentScore" />
            <Arg For="_ => _.ChildContent" Value="_CallbackContent" />
        </Arguments>
        <Template>
            <PlaygroundCard ScoreChanged="OnScoreChanged" @attributes="context.Args" />
            <p style="margin-top: 12px;"><b>Current score from callback:</b> @_CurrentScore</p>
        </Template>
    </Story>
</Stories>

@code
{
    private string _DefaultTitle = "API Playground Card";

    private string _WideTitle = "Full-frame card";

    private string _CallbackTitle = "Callback-driven score";

    private int _CurrentScore = 5;

    private Dictionary<string, object> _CardAttributes = new()
    {
        ["data-testid"] = "playground-card"
    };

    private RenderFragment _DefaultContent = @<text>Use controls to explore args in real time.</text>;

    private RenderFragment _WideContent = @<text>This story intentionally uses the full-frame layout.</text>;

    private RenderFragment _CallbackContent = @<text>Click +/- to trigger <code>ScoreChanged</code>.</text>;

    private void OnScoreChanged(int nextValue)
    {
        this._CurrentScore = nextValue;
    }
}
