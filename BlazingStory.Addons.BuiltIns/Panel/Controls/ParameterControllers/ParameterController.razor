@using BlazingStory.Addons.BuiltIns.Panel.Controls.ParameterControllers.Controllers
@using static System.Diagnostics.CodeAnalysis.DynamicallyAccessedMemberTypes

<CascadingValue Value="@(new ParameterControllerContext(@Key, @Parameter, @Value, @OnInput))">
    @if (this.Parameter.UserControllerFragment != null)
    {
        @this.Parameter.UserControllerFragment
    }
    else
    {
        {
#pragma warning disable IL2111
        }
        <DynamicComponent Type="@GetParameterControllerType()" />
        {
#pragma warning restore IL2111
        }
    }
</CascadingValue>

@code
{
    /// <summary>Gets or sets the unique key identifying this controller instance.</summary>
    [Parameter, EditorRequired]
    public required string Key { get; set; }

    /// <summary>Gets or sets the component parameter metadata used to select and configure the appropriate controller.</summary>
    [Parameter, EditorRequired]
    public required IComponentParameter Parameter { get; set; }

    /// <summary>Gets or sets the current value of the parameter.</summary>
    [Parameter, EditorRequired]
    public object? Value { get; set; }

    /// <summary>Gets or sets the callback invoked when the user changes the parameter value.</summary>
    [Parameter]
    public EventCallback<ParameterInputEventArgs> OnInput { get; set; }

    [return: DynamicallyAccessedMembers(PublicConstructors | PublicMethods | PublicProperties)]
    private Type GetParameterControllerType()
    {
        switch (this.Parameter.TypeStructure.PrimaryType)
        {
            case Type t when t == typeof(string): return typeof(TextParameterController);
            case Type t when t == typeof(bool): return typeof(BoolParameterController);
            case Type t when t.IsEnum: return typeof(EnumParameterController);
            case Type t when TypeUtility.IsNumericType(t): return typeof(NumberParameterController);
            case Type t when IsArrayOrListType(t): return typeof(ArrayParameterController);
            case Type t when RenderFragmentKit.IsRenderFragment(t): return typeof(RenderFragmentParameterController);
            default: return typeof(UnsupportedParameterController);
        };
    }

    private static bool IsArrayOrListType(Type type)
    {
        if (type.IsArray) return true;
        return type.IsGenericType
            && typeof(System.Collections.IEnumerable).IsAssignableFrom(type)
            && type.GetGenericArguments().Length == 1;
    }
}