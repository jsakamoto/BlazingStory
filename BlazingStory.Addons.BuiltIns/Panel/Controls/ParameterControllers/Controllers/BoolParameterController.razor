@inherits ParameterControllerBase
@{
    var nullable = this.Context.Parameter.TypeStructure.IsNullable;
}
@if (this.Context.Value is Unknown || (!nullable && this.Context.Value is null))
{
    <SquareButton OnClick="@(() => OnInputAsync(false))">Set boolean</SquareButton>
}
else if (nullable)
{
    var isNull = this.Context.Value == null;

    <div class="bool-parameter-controller">

        <NullInputRadio Name="@(this.Context.Key + "-value-type")" Checked="isNull" OnChange="() => OnInputAsync(null)" />

        <label class="input-value">
            <input type="radio" name="@(this.Context.Key + "-value-type")" checked="@(!isNull)" @onchange="() => OnInputAsync(this._BoolValue)" />
            <ToggleButton Value="_BoolValue" OnChange="OnChangeBoolValue" />
        </label>

    </div>
}
else
{
    <ToggleButton Value="_BoolValue" OnChange="OnChangeBoolValue" />
}

@code
{
    private bool _BoolValue;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        this._BoolValue = bool.TryParse(this.Context.Value?.ToString(), out var n) ? n : this._BoolValue;
    }

    private async Task OnChangeBoolValue()
    {
        this._BoolValue = !this._BoolValue;
        await this.OnInputAsync(this._BoolValue);
    }
}
