@inherits ParameterControllerBase

@if (this.Context.Parameter?.Control is ControlType.Color)
{
    var colorValue = (this.Context.Value ?? this.Context.Parameter.DefaultValue) as string;
    <ColorInput Value="@colorValue" PlaceHolder="Choose color..." OnInput="@((args) => OnInputAsync(args.Value))" />
}
else
{
    <TextArea PlaceHolder="Edit string..." Value="@(this.Context.Value as string)" OnInput="@((args) => OnInputAsync(args.Value))" />
}
