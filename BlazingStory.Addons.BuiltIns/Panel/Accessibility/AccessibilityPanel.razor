@using BlazingStory.Addons.BuiltIns.Panel.Accessibility.Axe
@using Microsoft.Extensions.DependencyInjection
@implements IDisposable
@inject IJSRuntime JSRuntime

<PanelTitle>
    Accessibility Report
    @if ((this._AxeResults?.Violations?.Count() ?? 0) > 0)
    {
        <Badge Text="@this._AxeResults?.Violations.Count().ToString()" />
    }
</PanelTitle>

<ImportStyleSheet Href="./_content/BlazingStory.Addons.BuiltIns/css/a11y-panel.min.css" />

<div class="a11y-panel">
    <div class="a11y-overview" role="status" aria-live="polite">
        <div class="a11y-overview-title">Quick Accessibility Overview</div>
        <div class="a11y-severity-legend" aria-label="Severity legend">
            <button type="button" class="@GetLegendItemClass(SeverityFilter.All)"
                    @onclick="() => SetSeverityFilter(SeverityFilter.All)">All severities</button>
            <button type="button" class="@GetLegendItemClass(SeverityFilter.Critical)"
                    @onclick="() => SetSeverityFilter(SeverityFilter.Critical)">Critical</button>
            <button type="button" class="@GetLegendItemClass(SeverityFilter.Serious)"
                    @onclick="() => SetSeverityFilter(SeverityFilter.Serious)">Serious</button>
            <button type="button" class="@GetLegendItemClass(SeverityFilter.Moderate)"
                    @onclick="() => SetSeverityFilter(SeverityFilter.Moderate)">Moderate</button>
            <button type="button" class="@GetLegendItemClass(SeverityFilter.Minor)"
                    @onclick="() => SetSeverityFilter(SeverityFilter.Minor)">Minor</button>
        </div>

        @if (this._WaitingForReady)
        {
            <div class="a11y-overview-message">Preparing the preview so we can run the accessibility scan.</div>
        }
        else if (this._IsRunningScan)
        {
            <div class="a11y-overview-message">Scanning the current story now. Results will appear in a few seconds.</div>
        }
        else if (this._AxeResults is null)
        {
            <div class="a11y-overview-message">No report yet. Open a story to trigger the first scan, or click "Run scan".
            </div>
        }
        else
        {
            <div class="a11y-overview-message">@GetOverviewMessage()</div>

            <div class="a11y-overview-stats">
                <button type="button" class="a11y-stat-button" @onclick="() => _currentView = View.Violations">
                    Needs fixing
                    <Badge Text="@GetViolationsCount().ToString()" />
                </button>
                <button type="button" class="a11y-stat-button" @onclick="() => _currentView = View.Inconclusive">
                    Needs review
                    <Badge Text="@GetInconclusiveCount().ToString()" />
                </button>
                <button type="button" class="a11y-stat-button" @onclick="() => _currentView = View.Passes">
                    Passed
                    <Badge Text="@GetPassesCount().ToString()" />
                </button>
            </div>
        }
    </div>

    <ToolBar>
        <TabButtonGroup>
            <TabButton Active="@(_currentView == View.Violations)" OnClick="@(() => _currentView = View.Violations)">
                Needs fixing
                <Badge Text="@GetFilteredViolationsCount().ToString()" />
            </TabButton>
            <TabButton Active="@(_currentView == View.Passes)" OnClick="@(() => _currentView = View.Passes)">
                Passed
                <Badge Text="@GetFilteredPassesCount().ToString()" />
            </TabButton>
            <TabButton Active="@(_currentView == View.Inconclusive)"
                       OnClick="@(() => _currentView = View.Inconclusive)">
                Needs review
                <Badge Text="@GetFilteredInconclusiveCount().ToString()" />
            </TabButton>
        </TabButtonGroup>

        <Spacer />

        @if (GetCurrentExpansionStateRef() == ExpansionState.ExpandedAll)
        {
            <button type="button" class="a11y-toolbar-button" title="Collapse all results"
                    @onclick="() => SetCurrentExpansionState(ExpansionState.CollapsedAll)">
                Collapse all
            </button>
        }
        else
        {
            <button type="button" class="a11y-toolbar-button" title="Expand all results"
                    @onclick="() => SetCurrentExpansionState(ExpansionState.ExpandedAll)">
                Expand all
            </button>
        }

        <button type="button" class="a11y-toolbar-button" title="Rerun accessibility scan"
                @onclick="() => RequestAxeRunAsync(force: true)">
            Run scan
        </button>
    </ToolBar>

    <div class="axe-results-views-container">
        @if (this._AxeResults is not null && GetCurrentFilteredResultsCount() == 0)
        {
            <div class="a11y-empty-state">@GetEmptyStateMessage()</div>
        }

        <AxeResultsView Results="GetFilteredResults(this._AxeResults?.Violations)"
                        Visible="(_currentView == View.Violations)" @bind-ExpansionState="_ViolationsExpansionState"
                        @bind-ExpansionState:after="OnExpansionStateChanged" />
        <AxeResultsView Results="GetFilteredResults(this._AxeResults?.Passes)" Visible="(_currentView == View.Passes)"
                        @bind-ExpansionState="_PassesExpansionState" @bind-ExpansionState:after="OnExpansionStateChanged" />
        <AxeResultsView Results="GetFilteredResults(this._AxeResults?.Incomplete)"
                        Visible="(_currentView == View.Inconclusive)" @bind-ExpansionState="_InconclusiveExpansionState"
                        @bind-ExpansionState:after="OnExpansionStateChanged" />
    </div>
</div>

@code
{
    [CascadingParameter(Name = "Story")]
    public IStory? Story { get; set; }

    [CascadingParameter]
    protected IServiceProvider Services { get; init; } = default!;

    private enum View { Violations, Passes, Inconclusive }

    private enum SeverityFilter { All, Critical, Serious, Moderate, Minor }

    private View _currentView = View.Violations;

    private Window? _Window;

    private IDisposable? _WindowMessageSubscription;

    private IStory? _PrevStory;

    private AxeResults? _AxeResults;

    private ExpansionState _ViolationsExpansionState = ExpansionState.CollapsedAll;

    private ExpansionState _PassesExpansionState = ExpansionState.CollapsedAll;

    private ExpansionState _InconclusiveExpansionState = ExpansionState.CollapsedAll;

    private bool _WaitingForReady = false;

    private bool _IsRunningScan = false;

    private SeverityFilter _severityFilter = SeverityFilter.All;

    protected override void OnInitialized()
    {
        this._Window = this.Services.GetRequiredService<Window>();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && this._Window is not null)
        {
            this._WindowMessageSubscription = await this._Window.SubscribeMessageAsync(OnMessageReceived);
        }

        // When the story changes, we need to ask the preview frame if it's ready to run Axe against the new story.
        if (this._PrevStory != this.Story && this._Window is not null)
        {
            // Prevent recursive calls to this method while waiting for the preview frame to be ready.
            if (this._WaitingForReady) return;

            this._WaitingForReady = true;
            this._AxeResults = null;

            try
            {
                for (var millisecondsDelay = 100; millisecondsDelay <= 3600 && this._PrevStory != this.Story; millisecondsDelay *= 2)
                {
                    await this._Window.PostMessageAsync(".preview-frame iframe", AccessibilityPanelAddon.Message.AskReady);
                    await Task.Delay(millisecondsDelay);

                    // If after 100 ms we still don't have results, trigger a state change to clear the previous results.
                    if (millisecondsDelay == 100 && this._AxeResults is null) this.StateHasChanged();
                }
            }
            catch (JSDisconnectedException) { }
            finally { this._WaitingForReady = false; }
        }
    }

    private async Task OnMessageReceived(string? message)
    {
        if (message == AccessibilityPanelAddon.Message.Ready)
        {
            await RequestAxeRunAsync();
        }
        else if (message?.StartsWith(AccessibilityPanelAddon.Message.AxeResult) == true)
        {
            await OnReceiveAxeResultAsync(message.Substring(AccessibilityPanelAddon.Message.AxeResult.Length));
        }
    }

    private async Task RequestAxeRunAsync(bool force = false)
    {
        if (!force && this._PrevStory == this.Story) return;
        this._PrevStory = this.Story;
        this._IsRunningScan = true;
        this._AxeResults = null;
        this._ViolationsExpansionState = ExpansionState.CollapsedAll;
        this._PassesExpansionState = ExpansionState.CollapsedAll;
        this._InconclusiveExpansionState = ExpansionState.CollapsedAll;
        this.StateHasChanged();
        if (this._Window is not null)
        {
            await this._Window.PostMessageAsync(".preview-frame iframe", AccessibilityPanelAddon.Message.RunAxe);
        }
    }

    [UnconditionalSuppressMessage("Trimming", "IL2026", Justification = "AxeResults and all referenced types are preserved via [DynamicallyAccessedMembers(All)].")]
    private async Task OnReceiveAxeResultAsync(string resultObjectUrl)
    {
        if (string.IsNullOrWhiteSpace(resultObjectUrl)) return;

        try
        {
            // The Axe results are expected to be a JSON string, but we fetch it as a blob from the object URL
            // and then open a stream to deserialize it,
            // because the results can be quite big and this way we avoid loading the whole content in memory as a string.
            await using var response = await JSRuntime.InvokeAsync<IJSObjectReference>("fetch", resultObjectUrl);
            await using var blob = await response.InvokeAsync<IJSStreamReference>("blob");
            using var stream = await blob.OpenReadStreamAsync();
            this._AxeResults = await JsonSerializer.DeserializeAsync<AxeResults>(stream, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
        }
        catch (JSDisconnectedException) { }
        finally
        {
            this._IsRunningScan = false;
            this.StateHasChanged();
            try { await JSRuntime.InvokeVoidAsync("URL.revokeObjectURL", resultObjectUrl); }
            catch (JSDisconnectedException) { }
        }
    }

    private int GetViolationsCount() => this._AxeResults?.Violations.Count() ?? 0;

    private int GetPassesCount() => this._AxeResults?.Passes.Count() ?? 0;

    private int GetInconclusiveCount() => this._AxeResults?.Incomplete.Count() ?? 0;

    private string GetCurrentViewLabel() => this._currentView switch
    {
        View.Violations => "Needs fixing",
        View.Passes => "Passed",
        View.Inconclusive => "Needs review",
        _ => throw new InvalidOperationException()
    };

    private int GetCurrentResultsCount() => this._currentView switch
    {
        View.Violations => GetViolationsCount(),
        View.Passes => GetPassesCount(),
        View.Inconclusive => GetInconclusiveCount(),
        _ => throw new InvalidOperationException()
    };

    private int GetCurrentFilteredResultsCount() => this._currentView switch
    {
        View.Violations => GetFilteredViolationsCount(),
        View.Passes => GetFilteredPassesCount(),
        View.Inconclusive => GetFilteredInconclusiveCount(),
        _ => throw new InvalidOperationException()
    };

    private int GetFilteredViolationsCount() => GetFilteredResults(this._AxeResults?.Violations).Count();

    private int GetFilteredPassesCount() => GetFilteredResults(this._AxeResults?.Passes).Count();

    private int GetFilteredInconclusiveCount() => GetFilteredResults(this._AxeResults?.Incomplete).Count();

    private IEnumerable<Result> GetFilteredResults(IEnumerable<Result>? results)
    {
        var source = results ?? [];
        if (this._severityFilter == SeverityFilter.All) return source;

        var impact = this._severityFilter switch
        {
            SeverityFilter.Critical => "critical",
            SeverityFilter.Serious => "serious",
            SeverityFilter.Moderate => "moderate",
            SeverityFilter.Minor => "minor",
            _ => throw new InvalidOperationException()
        };

        return source.Where(result => string.Equals(result.Impact, impact, StringComparison.OrdinalIgnoreCase));
    }

    private void SetSeverityFilter(SeverityFilter severityFilter)
    {
        this._severityFilter = severityFilter;
        this.SetCurrentExpansionState(ExpansionState.CollapsedAll);
    }

    private string GetLegendItemClass(SeverityFilter severityFilter)
    {
        var cssClass = "legend-item";
        if (severityFilter == SeverityFilter.Critical) cssClass += " severity-critical";
        if (severityFilter == SeverityFilter.Serious) cssClass += " severity-serious";
        if (severityFilter == SeverityFilter.Moderate) cssClass += " severity-moderate";
        if (severityFilter == SeverityFilter.Minor) cssClass += " severity-minor";
        if (this._severityFilter == severityFilter) cssClass += " active";
        return cssClass;
    }

    private string GetSeverityFilterLabel() => this._severityFilter switch
    {
        SeverityFilter.All => "All severities",
        SeverityFilter.Critical => "Critical",
        SeverityFilter.Serious => "Serious",
        SeverityFilter.Moderate => "Moderate",
        SeverityFilter.Minor => "Minor",
        _ => throw new InvalidOperationException()
    };

    private string GetEmptyStateMessage()
    {
        var viewLabel = GetCurrentViewLabel();
        if (this._severityFilter == SeverityFilter.All)
        {
            return $"No items in \"{viewLabel}\". Try another tab for more details.";
        }

        return $"No {GetSeverityFilterLabel().ToLowerInvariant()} items in \"{viewLabel}\". Try another severity or tab.";
    }

    private string GetOverviewMessage()
    {
        var violations = GetViolationsCount();
        var review = GetInconclusiveCount();
        var passed = GetPassesCount();

        if (violations == 0 && review == 0)
        {
            return $"Great job. This story passed {passed} automated accessibility checks.";
        }

        return $"Found {violations} issues to fix and {review} items to review manually. Start with \"Needs fixing\" for highest impact.";
    }

    private void OnExpansionStateChanged()
    {
        /* NOP, Just kick the state change */
    }

    private ref ExpansionState GetCurrentExpansionStateRef()
    {
        switch (this._currentView)
        {
            case View.Violations: return ref this._ViolationsExpansionState;
            case View.Passes: return ref this._PassesExpansionState;
            case View.Inconclusive: return ref this._InconclusiveExpansionState;
            default: throw new InvalidOperationException();
        }
    }

    private void SetCurrentExpansionState(ExpansionState state)
    {
        var currentResults = this._currentView switch
        {
            View.Violations => GetFilteredResults(this._AxeResults?.Violations),
            View.Passes => GetFilteredResults(this._AxeResults?.Passes),
            View.Inconclusive => GetFilteredResults(this._AxeResults?.Incomplete),
            _ => throw new InvalidOperationException()
        };

        GetCurrentExpansionStateRef() = (currentResults?.Count() ?? 0) > 0 ? state : ExpansionState.CollapsedAll;
    }

    public void Dispose()
    {
        this._Window = null;
        this._WindowMessageSubscription?.Dispose();
    }
}