@using BlazingStory.Addons.BuiltIns.Panel.Accessibility.Axe

<div class="@CssClass("axe-result-view", new { expanded = Expanded })">

    <button type="button" class="header" aria-expanded="@Expanded" @onclick="OnClickHeader">
        <span class="title">
            @Capitalize(this.Result.Id)
        </span>
        <span class="id">
            @this.Result.Id
        </span>
        <span class="spacing" />
        <span class="@CssClass("impact", new { impact = this.Result.Impact })">
            @Capitalize(this.Result.Impact)
        </span>
        <span class="number-of-nodes">
            @this.Result.Nodes.Count()
        </span>
        <SvgIcon Type="SvgIconType.Chevron" Class="expansion-indicator">
        </SvgIcon>
    </button>

    <div class="details">
        <div class="details-inner">
            <div class="details-content">

                <div class="guidance">
                    <section class="guidance-section what-this-means">
                        <div class="guidance-caption">What this means</div>
                        <p class="guidance-text">@Result.Description</p>
                    </section>

                    <section class="guidance-section how-to-fix">
                        <div class="guidance-caption">How to fix</div>
                        <p class="guidance-text">@Result.Help</p>
                        <a class="help-link" href="@Result.HelpUrl" target="_blank" rel="noopener noreferrer">
                            Open step-by-step fix guide &gt;
                        </a>
                    </section>

                    @if (Result.Tags.Any(tag => !string.IsNullOrWhiteSpace(tag)))
                    {
                        <div class="tags" aria-label="Accessibility categories">
                            @foreach (var tag in Result.Tags.Where(tag => !string.IsNullOrWhiteSpace(tag)))
                            {
                                <span class="tag">@tag</span>
                            }
                        </div>
                    }
                </div>

                <AxeNodesView Nodes="Result.Nodes" />

            </div>
        </div>
    </div>

</div>

@code
{
    [Parameter, EditorRequired]
    public Result Result { get; set; }

    [Parameter]
    public bool Expanded { get; set; }

    [Parameter]
    public EventCallback OnClickHeader { get; set; }

    private string Capitalize(string? text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return char.ToUpper(text[0]) + text.Substring(1).Replace('-', ' ');
    }
}