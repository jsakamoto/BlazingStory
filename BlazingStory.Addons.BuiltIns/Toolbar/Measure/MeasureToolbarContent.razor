@inject IJSRuntime JSRuntime

<IconButton Icon="SvgIconType.Measure"
            Title="Enable measure"
            Active="this._Enable"
            OnClick="OnClickButton" />

@code
{
    [Parameter]
    public required GlobalArguments Globals { get; init; }

    private bool _Enable = false;

    private static class StorageKeys
    {
        public const string Measure = "Addons.Measure";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var enableStr = await this.JSRuntime.GetLocalStorageItemAsync(StorageKeys.Measure);
        this._Enable = bool.TryParse(enableStr, out var enable) ? enable : this._Enable;
        this.StateHasChanged();
        this.UpdateGlobalArguments();
    }

    private async Task OnClickButton()
    {
        this._Enable = !this._Enable;
        this.UpdateGlobalArguments();
        await this.JSRuntime.SetLocalStorageItemAsync(StorageKeys.Measure, this._Enable);
    }

    private void UpdateGlobalArguments()
    {
        this.Globals["measureEnabled"] = this._Enable ? "true" : null;
    }
}