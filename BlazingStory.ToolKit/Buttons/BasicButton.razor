@if (string.IsNullOrEmpty(this.Href))
{
    <button class="@("basic-button " + this.Class)" title="@this.Title" @onclick="this.OnClick">
        @ChildContent
    </button>
}
else
{
    <a class="@("basic-button " + this.Class)" title="@this.Title" @onclick="this.OnClick" href="@this.Href" target="@this.Target">
        @ChildContent
    </a>
}

@code {
    /// <summary>
    /// The content to be rendered inside the button, such as text or icons.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Callback invoked when the button is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>
    /// The tooltip text shown on hover.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Additional CSS class names to apply to the button or anchor element.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// When set, renders the component as an anchor element navigating to this URL.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// The anchor target attribute used when <see cref="Href"/> is set.
    /// </summary>
    [Parameter]
    public string? Target { get; set; }
}