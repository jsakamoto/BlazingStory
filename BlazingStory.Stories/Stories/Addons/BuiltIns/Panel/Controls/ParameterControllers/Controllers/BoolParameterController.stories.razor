            </Stack>
            <p>@(_V3?.ToString() ?? "(null)")</p>
        </Template>
    </Story>
</Stories>

@code
{
    private readonly IComponentParameter Bool = SampleComponent.CreateParameter(nameof(SampleComponent.Bool));

    private readonly IComponentParameter NullableBool = SampleComponent.CreateParameter(nameof(SampleComponent.NullableBool));

    private object? _V1 = Unknown.Value;

    private object? _V2 = true;

    private object? _V3 = null;
}