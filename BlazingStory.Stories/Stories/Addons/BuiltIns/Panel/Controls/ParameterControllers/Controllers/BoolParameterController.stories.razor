@using BlazingStory.Addons.BuiltIns.Panel.Controls.ParameterControllers
@attribute [Stories("Addons/BuiltIns/Panel/Controls/ParameterControllers/Controllers/BoolParameterController")]

<Stories TComponent="BoolParameterController">

    <Story Name="Nullable - No Value">
        <Template>
            <Stack>
                <CascadingValue Value="@(new ParameterControllerContext("key", NullableBool, _V1, EventCallback.Factory.Create<ParameterInputEventArgs>(this, arg => _V1 = arg.Value)))">
                    <BoolParameterController />
                </CascadingValue>
                <ResetButton OnClick="() => _V1 = Unknown.Value" />
            </Stack>
            <p>@(_V1?.ToString() ?? "(null)")</p>
        </Template>
    </Story>

    <Story Name="Nullable - Initial Value">
        <Template>
            <Stack>
                <CascadingValue Value="@(new ParameterControllerContext("key", NullableBool, _V2, EventCallback.Factory.Create<ParameterInputEventArgs>(this, arg => _V2 = arg.Value)))">
