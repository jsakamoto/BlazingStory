@using BlazingStory.Configurations
@using static BlazingStory.Types.NavigationTreeOrderBuilder

<SvgIcons />

<BlazingStoryApp Assemblies="[typeof(App).Assembly]"
                 OnInitialize="OnInitialize">
</BlazingStoryApp>

@code 
{
    private void OnInitialize(IBlazingStoryBuilder builder)
    {
        builder.Options.EnableHotReloading = true;
        builder.Options.NavigationTreeOrder = N["ToolKit", "Internals", N["Components", "Pages", N["Canvas", N["Controls"]]]];
    }
}