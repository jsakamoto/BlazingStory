@using BlazingStory.Configurations
@using static BlazingStory.Types.NavigationTreeOrderBuilder

<SvgIcons />

@* This sample enables the built-in Accessibility Report so the UI is visible out of the box.
    Add custom accessibility rules in a custom addon registered from OnInitialize if needed. *@
<BlazingStoryApp Assemblies="[typeof(App).Assembly]" EnableAccessibilityReport="true" OnInitialize="OnInitialize">
</BlazingStoryApp>

@code
{
    private void OnInitialize(IBlazingStoryBuilder builder)
    {
        builder.Options.EnableHotReloading = true;
        builder.Options.NavigationTreeOrder = N["ToolKit", "Internals", N["Components", "Pages", N["Canvas", N["Controls"]]]];
    }
}