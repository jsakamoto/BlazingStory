@using System.Collections
@using System.Globalization
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<IntersectionView @ref="_IntersectionView"
                  class="preview-frame"
                  @onframeheightchange="FrameHeightChangeEventCallback">
    <PooledIFrame Src="@_PreviewFrameUrl" Attached="OnPreviewIFrameAttached" />
</IntersectionView>

@code
{
    [Parameter, EditorRequired]
    public required IStory Story { get; set; }

    [Parameter]
    public string? ViewMode { get; set; }

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, object?>? Args { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, object?>? Globals { get; set; }

    [Parameter]
    public EventCallback<int> OnFrameHeightChanged { get; set; }

    [CascadingParameter]
    internal IServiceProvider Services { get; init; } = default!;

    /// <summary>
    /// Gets the initial preview frame URL.
    /// </summary>
    public string CurrentPreviewFrameUrl => this._PreviewFrameUrl;

    private IntersectionView? _IntersectionView;

    private ElementReference _IframeContainer => this._IntersectionView?.ElementReference ?? default;

    private string _PreviewFrameUrl = "";

    private readonly JSModule _JSModule;

    /// <summary>
    /// Initializes a new instance of the <see cref="PreviewFrame"/> class.
    /// </summary>
    public PreviewFrame()
    {
        this._JSModule = JSModuleFactory.Create(() => this.JSRuntime, "Internals/Components/Preview/PreviewFrame.razor.js");
    }

    protected override async Task OnInitializedAsync()
    {
        this._PreviewFrameUrl = await this.GetPreviewFrameUrlAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        this._PreviewFrameUrl = await this.GetPreviewFrameUrlAsync();
    }

    private async Task OnPreviewIFrameAttached()
    {
        try
        {
            var options = Services.GetRequiredService<BlazingStoryOptions>();
            if (options.EnableHotReloading)
            {
                await EnsureDotnetWatchScriptInjected();
            }

            var frameHeight = await _JSModule.InvokeAsync<int>("getFrameHeight", this._IframeContainer);
            await this.OnFrameHeightChanged.InvokeAsync(frameHeight);
        }

        // In some cases, such as when a user navigates away from the page during this async operation,
        // the JSModule may be disposed before the async operation completes.
        // Ignore the "ObjectDisposedException" exception in this case.
        catch (ObjectDisposedException) { }
    }

    /// <summary>
    /// Gets the URL for the preview frame, from the component parameters(args).
    /// </summary>
    private async ValueTask<string> GetPreviewFrameUrlAsync()
    {
        // "Stringify" the component args to encode them to the URL query string.
        var args = new Dictionary<string, object?>();
        foreach (var arg in this.Args?.AsEnumerable() ?? [])
        {
            args[arg.Key] = await this.ConvertParameterValueToStringAsync(arg.Key, arg.Value);
        }

        return UriParameterKit.GetUri(
            uri: "./iframe.html",
            parameters: new Dictionary<string, object?>
            {
                ["viewMode"] = this.ViewMode,
                ["id"] = this.Id,
                ["args"] = UriParameterKit.EncodeKeyValues(args),
                ["globals"] = UriParameterKit.EncodeKeyValues(this.Globals)
            });
    }

    [UnconditionalSuppressMessage("Trimming", "IL2060")]
    private async ValueTask<string> ConvertParameterValueToStringAsync(string name, object? value)
    {
        static string ToFormattedString(object? obj) => obj switch
        {
            null => "(null)",
            IFormattable f => f.ToString(format: null, formatProvider: CultureInfo.InvariantCulture),
            _ => obj.ToString() ?? ""
        };

        static string EscapeCollectionItemString(string str) => str.Replace("%", "%25").Replace(",", "%2c");

        return await RenderFragmentKit.TryToMarkupStringAsync(value, fallback: _ =>
        {
            if (this.Story.Context.Parameters.TryGetByName(name, out var param))
            {
                if (param.TypeStructure.IsNullable && value == null) return ToFormattedString(value);

                // If the type of the parameter is compatible with IEnumerable, render the value as a list of items.
                if (param.TypeStructure.PrimaryType.IsAssignableTo(typeof(IEnumerable)))
                {
                    var enumerable = value as IEnumerable;
                    if (enumerable == null) return ToFormattedString(value);
                    var items = new List<string>();
                    foreach (var item in enumerable)
                    {
                        items.Add(EscapeCollectionItemString(ToFormattedString(item)));
                    }
                    return string.Join(",", items);
                }
            }
            return ToFormattedString(value);
        });
    }

    internal async ValueTask ReloadAsync()
    {
        await this._JSModule.InvokeVoidAsync("reloadPreviewFrame", this._IframeContainer);
    }

    internal async ValueTask ZoomInAsync()
    {
        await this._JSModule.InvokeVoidAsync("zoomInPreviewFrame", this._IframeContainer);
    }

    internal async ValueTask ZoomOutAsync()
    {
        await this._JSModule.InvokeVoidAsync("zoomOutPreviewFrame", this._IframeContainer);
    }

    internal async ValueTask ResetZoomAsync()
    {
        await this._JSModule.InvokeVoidAsync("resetZoomPreviewFrame", this._IframeContainer);
    }

    private async ValueTask EnsureDotnetWatchScriptInjected()
    {
        await this._JSModule.InvokeVoidAsync("ensureDotnetWatchScriptInjected", this._IframeContainer);
    }

    /// <summary>
    /// Invoked when the frame height changes.
    /// </summary>
    private async Task FrameHeightChangeEventCallback(FrameHeightChangeEventArgs args)
    {
        await this.OnFrameHeightChanged.InvokeAsync(args.Height);
    }

    public async ValueTask DisposeAsync()
    {
        await _JSModule.DisposeAsync();
    }
}