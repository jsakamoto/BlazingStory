<PopupMenu Class="settings-popup-menu">
    <Trigger>
        <IconButton Icon="SvgIconType.Gear" Title="Shortcuts" />
    </Trigger>
    <MenuItems>
        @foreach (var commandSegment in this._CommandSegments)
        {
            if (commandSegment.Key != 1)
            {
                <MenuItemDivider />
            }
            @foreach (var command in commandSegment)
            {
                <CommandMenuItem Command="command" />
            }
        }
    </MenuItems>
</PopupMenu>

@code
{
    [CascadingParameter]
    protected IServiceProvider Services { get; init; } = default!;

    private IEnumerable<IGrouping<int, Command>> _CommandSegments = [];

    protected override void OnInitialized()
    {
        var commandService = this.Services.GetRequiredService<CommandService>();
        var topCommandsTypes = new[] {
            CommandType.AboutYourBlazingStory,
            CommandType.ReleaseNotes,
            CommandType.KeyboardShortcuts,
        };
        var lastCommandsTypes = new[] {
            CommandType.Documentation,
        };
        this._CommandSegments = commandService.Commands
            .GroupBy(cmd => cmd.Type switch
            {
                var t when topCommandsTypes.Contains(t) => 1,
                var t when lastCommandsTypes.Contains(t) => 3,
                _ => 2
            },
            cmd => cmd.Command);
    }
}