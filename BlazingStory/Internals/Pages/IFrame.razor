@page "/iframe.html"
@layout NullLayout
@inject IJSRuntime JSRuntime

<IdQueryRouter>
    <CanvasFrame />
</IdQueryRouter>

@code
{
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await using var module = JSModuleFactory.Create(() => this.JSRuntime, "Internals/Pages/IFrame.razor.js");
        await module.InvokeVoidAsync("initializeCanvasFrame");
    }
}