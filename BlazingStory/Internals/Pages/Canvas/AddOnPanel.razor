@using BlazingStory.Addons
@using BlazingStory.Addons.Internals
@using Microsoft.AspNetCore.Components.Sections

<div class="add-on-panel fill stack vertical">

    <ToolBar>
        <TabButtonGroup>
            @foreach (var panel in this.GetPanels())
            {
                <TabButton @key="panel.Id" Active="this._ActivePanel == panel" OnClick="() => this._ActivePanel = panel">
                    <SectionOutlet SectionName="@($"panel-title-{panel.Id:N}")" />
                </TabButton>
            }
        </TabButtonGroup>

        <Spacer />

        <IconCommandButton Icon="this.ToggleOrientationButtonIcon" Command="this._Commands[CommandType.AddonPanelOrientation]" />
        <IconCommandButton Icon="SvgIconType.CircleClose" Command="this._Commands[CommandType.AddonPanelVisible]" Title="Hide addons [{0}]" FlagStyle="false" />
    </ToolBar>

    <div class="fill add-on-panel-content">
        @{
#pragma warning disable IL2111
        }
        @foreach (var panel in this.GetPanels())
        {
            <CascadingValue Value="ViewMode.Story" IsFixed>
                <CascadingValue Name="Story" Value="this.Story">
                    <CascadingValue @key="panel.Id" Value="panel">
                        <div class="@CssClass("add-on-panel-pane", new { Active = _ActivePanel == panel })">
                            <DynamicComponent Type="panel.ComponentType" />
                        </div>
                    </CascadingValue>
                </CascadingValue>
            </CascadingValue>
        }
        @{
#pragma warning restore IL2111
        }
    </div>

</div>

@code
{
    [Parameter, EditorRequired]
    public Story? Story { get; set; }

    [Parameter]
    public SplitterOrientation SplitterOrientation { get; set; }

    [CascadingParameter]
    public required IServiceProvider Services { get; init; }

    [CascadingParameter]
    public required CanvasPageContext CanvasPageContext { get; init; }

    private CommandService _Commands = default!;

    private AddonManager AddonManager => this.Services.GetRequiredService<AddonManager>();

    private PanelDescriptor? _ActivePanel;

    private SvgIconType ToggleOrientationButtonIcon => this.SplitterOrientation switch
    {
        SplitterOrientation.Horizontal => SvgIconType.RightSidePane,
        _ => SvgIconType.BottomSidePane
    };

    protected override void OnInitialized()
    {
        this._Commands = this.Services.GetRequiredService<CommandService>();
        this._ActivePanel = this.GetPanels().FirstOrDefault();
    }

    private IEnumerable<PanelDescriptor> GetPanels()
    {
        return this.AddonManager.GetPanels(ViewMode.Story);
    }
}