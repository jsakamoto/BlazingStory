@using System.Collections.Specialized;
@using System.Web
@using BlazingStory.Addons.Internals

@implements IDisposable
@inject NavigationManager NavigationManager

@{
#pragma warning disable IL2111
#pragma warning disable IL2110
}
@if (this._Story == null)
{
    <CanvasFrameNothingToAddress />
}
else
{
    <LayoutView Layout="@(this.BlazingStoryApp.DefaultLayout ?? typeof(NullLayout))">
        <LayoutView Layout="@(this._Story.StoriesLayout ?? typeof(NullLayout))">
            <LayoutView Layout="@(this._Story.StoryLayout ?? typeof(NullLayout))">

                @this._Story.RenderFragment(this._Story.Context)

            </LayoutView>
        </LayoutView>
    </LayoutView>

    <CascadingValue Name="Globals" Value="this._Globals">
        <CascadingValue Name="Story" Value="this._Story">
            <CascadingValue Name="Args" Value="this._Args">
                @foreach (var previewDecorator in this.AddonManager.GetPreviewDecorators())
                {
                    <DynamicComponent @key="previewDecorator.Id"
                                      Type="previewDecorator.ComponentType" />
                }
            </CascadingValue>
        </CascadingValue>
    </CascadingValue>
}
@{
#pragma warning restore IL2111
#pragma warning restore IL2110
}

@code
{
    [CascadingParameter]
    protected IServiceProvider Services { get; init; } = default!;

    [CascadingParameter]
    protected StoriesStore StoriesStore { get; init; } = default!;

    [CascadingParameter]
    protected QueryRouteData RouteData { get; init; } = default!;

    [CascadingParameter]
    protected BlazingStoryApp BlazingStoryApp { get; init; } = default!;

    private AddonManager AddonManager => this.Services.GetRequiredService<AddonManager>();

    private Story? _Story;

    private string _ArgsString = "";

    private string _GlobalsString = "";

    private IReadOnlyDictionary<string, string> _Args = new Dictionary<string, string>();

    private IReadOnlyDictionary<string, string> _Globals = new Dictionary<string, string>();

    protected override void OnInitialized()
    {
        this.NavigationManager.LocationChanged += NavigationManager_LocationChanged;
    }

    protected override void OnParametersSet()
    {
        if (!this.StoriesStore.TryGetStoryByPath(this.RouteData.Parameter, out var story)) return;
        if (this._Story != null) this._Story.Context.ShouldRender -= StoryContext_ShouldRender;
        this._Story = story;
        this._Story.Context.ShouldRender += StoryContext_ShouldRender;
        this.UpdateComponentStates();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        this.UpdateComponentStates();
    }

    private void NavigationManager_LocationChanged(object? sender, LocationChangedEventArgs args)
    {
        this.UpdateComponentStates();
    }

    private void UpdateComponentStates()
    {
        var queryStrings = HttpUtility.ParseQueryString(new Uri(this.NavigationManager.Uri).Query);
        var isUpdatedArgs = this.DecodeQueryParams(queryStrings, "args", ref this._ArgsString, ref this._Args);
        var isUpdatedGlobals = this.DecodeQueryParams(queryStrings, "globals", ref this._GlobalsString, ref this._Globals);

        if (isUpdatedArgs || isUpdatedGlobals) this.StateHasChanged();
    }

    private bool DecodeQueryParams(NameValueCollection queryStrings, string key, ref string prevValue, ref IReadOnlyDictionary<string, string> keyValues)
    {
        var valueString = queryStrings[key] ?? "";
        if (prevValue == valueString) return false;

        prevValue = valueString;
        keyValues = UriParameterKit.DecodeKeyValues(valueString);
        return true;
    }

    /// <summary>
    /// When the state of the story has been changed, this canvas frame should be re-rendered.
    /// </summary>
    private void StoryContext_ShouldRender(object? sender, EventArgs e)
    {
        this.StateHasChanged();
    }

    public void Dispose()
    {
        if (this._Story != null) this._Story.Context.ShouldRender -= StoryContext_ShouldRender;
        this.NavigationManager.LocationChanged -= NavigationManager_LocationChanged;
    }
}